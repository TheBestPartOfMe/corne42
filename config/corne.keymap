#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    behaviors {
        HMR_L: HMR_L {
            compatible = "zmk,behavior-hold-tap";
            label = "HMR_L";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            flavor = "tap-preferred";
            hold-trigger-on-release;
            hold-trigger-key-positions = <6 7 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 38 39 40 41 8 37 36>;
        };

        HMR_R: HMR_R {
            compatible = "zmk,behavior-hold-tap";
            label = "HMR_R";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            flavor = "tap-preferred";
            hold-trigger-on-release;
            hold-trigger-key-positions = <0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29 36 37 38 39 40 41>;
        };

        hmr_l_layer: hmr_l_layer {
            compatible = "zmk,behavior-hold-tap";
            label = "HMR_L_LAYER";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            hold-trigger-key-positions = <6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 39 40 41 38 37 36>;
            hold-trigger-on-release;
        };

        // ^ and ` are dead keys on the German host layout (they combine with the
        // next keystroke instead of typing on their own), so producing the bare
        // character means tapping the dead key then Space.
        de_caret: de_caret {
            compatible = "zmk,behavior-macro";
            label = "DE_CARET";
            #binding-cells = <0>;
            bindings = <&kp GRAVE>, <&kp SPACE>;
        };

        de_grave: de_grave {
            compatible = "zmk,behavior-macro";
            label = "DE_GRAVE";
            #binding-cells = <0>;
            bindings = <&kp LS(EQUAL)>, <&kp SPACE>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BKSP |
            // | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
            // | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
            //                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |

            display-name = "Base";
            bindings = <
&kp ESCAPE  &kp J            &kp D           &kp U             &kp A              &kp X               &kp P    &kp H          &kp L      &kp M           &kp W                &kp DELETE
&kp TAB     &HMR_L LSHIFT C  &HMR_L LCTRL T  &kp I             &kp E              &hmr_l_layer 3 O    &kp B    &kp N          &kp R      &HMR_R LCTRL S  &HMR_R LEFT_SHIFT G  &kp Q
&kp LSHFT   &kp F            &kp V           &kp LEFT_BRACKET  &kp APOSTROPHE     &kp SEMICOLON       &kp Z    &kp Y          &kp COMMA  &kp DOT         &kp K                &kp MINUS
                                             &kp LGUI          &mo 2              &kp SPACE           &kp RET  &kp BACKSPACE  &mo 1
            >;
        };

        lower_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BKSP |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
            // | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            display-name = "Lower";
            bindings = <
&kp EQUAL  &kp N1        &kp N2        &kp N3    &kp N4  &kp N5       &kp N6   &kp N7    &kp N8    &kp N9        &kp N0     &kp BSPC
&trans     &trans        &trans        &trans    &trans  &trans       &trans   &kp LEFT  &kp DOWN  &kp UP_ARROW  &kp RIGHT  &trans
&trans     &bt BT_SEL 0  &bt BT_SEL 1  &trans    &trans  &trans       &trans   &trans    &trans    &trans        &trans     &trans
                                       &kp LGUI  &trans  &kp SPACE    &kp RET  &trans    &kp RALT
            >;
        };

        raise_layer {
            // Neo2 "Ebene 3" (Sondertasten) — brackets & symbols, reachable by holding
            // this layer. Bindings assume a German (QWERTZ) host keyboard layout, since
            // ZMK only sends raw HID codes and the OS layout decides the actual glyph;
            // RA() = AltGr, LS() = Shift. ^ and ` go through the de_caret/de_grave
            // macros because they're dead keys in German (see behaviors above).
            // -----------------------------------------------------------------------------------------
            // |      |  …  |  _  |  [  |  ]  |  ^  |   |  !  |  <  |  >  |  =  |  &  |      |
            // |      |  \  |  /  |  {  |  }  |  *  |   |  ?  |  (  |  )  |  -  |  :  |      |
            // |      |  #  |  $  |  |  |  ~  |  `  |   |  +  |  %  |  "  |  '  |  ;  |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            display-name = "Raise";
            bindings = <
&kp EQUAL  &kp RA(PERIOD)  &kp LS(SLASH)  &kp RA(N8)          &kp RA(N9)           &de_caret       &kp LS(N1)  &kp NON_US_BSLH     &kp LS(NON_US_BSLH)  &kp LS(N0)           &kp LS(N6)     &none
&kp LCTRL  &kp RA(MINUS)   &kp LS(N7)     &kp RA(N7)          &kp RA(N0)           &kp LS(RIGHT_BRACKET)  &kp LS(MINUS)  &kp LS(N8)   &kp LS(N9)           &kp SLASH            &kp LS(PERIOD) &kp RA(Q)
&kp LSHFT  &kp NON_US_HASH &kp LS(N4)     &kp RA(NON_US_BSLH) &kp RA(RIGHT_BRACKET) &de_grave      &kp RIGHT_BRACKET  &kp LS(N5)      &kp LS(N2)           &kp LS(NON_US_HASH)  &kp LS(COMMA)  &none
                                          &kp LGUI            &trans               &kp SPACE       &kp RET     &trans              &none
            >;
        };

        layer_3 {
            // Math operators use the same German-layout HID trick as raise_layer:
            // + = RIGHT_BRACKET, - = SLASH, * = LS(RIGHT_BRACKET), / = LS(N7), = = LS(N0).
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &kp NUMBER_7  &kp N8        &kp N9        &kp RIGHT_BRACKET     &kp SLASH
&trans  &trans  &trans  &trans  &trans  &trans    &kp N0  &kp NUMBER_4  &kp NUMBER_5  &kp NUMBER_6  &kp LS(RIGHT_BRACKET) &kp LS(N7)
&trans  &trans  &trans  &trans  &trans  &trans    &trans  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp LS(N0)            &trans
                        &trans  &trans  &trans    &trans  &trans        &trans
            >;
        };
    };
};
